OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=openrouter-agent-search
BACKEND_API_BASE=http://127.0.0.1:8000
AGENT_PROMPT='查一下 OpenAI Responses API 是什么，并给我两句总结和来源链接。'

VERTEX_PROJECT_ID=your_vertex_project_id
VERTEX_LOCATION=global
VERTEX_COLLECTION=default_collection
VERTEX_ENGINE_ID=your_vertex_engine_id
VERTEX_SEARCH_PAGE_SIZE=5
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
